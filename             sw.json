const cacheName = 'meu-site-offline-v1';
const recursosParaCache = [
  './',
  './index.html',
  // Adicione aqui seus arquivos CSS ou Imagens
];

// Instala o Service Worker e guarda os arquivos no cache
self.addEventListener('install', (e) => {
  e.waitUntil(
    caches.open(cacheName).then((cache) => cache.addAll(recursosParaCache))
  );
});

// Serve o conteúdo do cache quando estiver offline
self.addEventListener('fetch', (e) => {
  e.respondWith(
    caches.match(e.request).then((response) => {
      return response || fetch(e.request);
    })
  );
});
